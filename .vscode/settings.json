{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/__pycache__": true,
    "**/.vscode": true,
    "**/.venv": true
  },
  "python.defaultInterpreterPath": ".\\.venv\\Scripts\\python.exe",
  "python.analysis.diagnosticMode": "workspace",
  "files.associations": {
    "*.lpm": "code-text-binary",
    "*.lpj": "json",
    "*.lpb": "code-text-binary",
    "*.lpk": "code-text-binary"
  }
}
